package demo;

module Main {
    public void main() {
        print("=== Testing List API Functions ===");

        // Test reverse
        print("--- Testing reverse() ---");
        int list1 = List.new();
        List.push(list1, 1);
        List.push(list1, 2);
        List.push(list1, 3);

        print(List.get(list1, 0));  // Should print 1
        print(List.get(list1, 2));  // Should print 3

        List.reverse(list1);

        print(List.get(list1, 0));  // Should print 3
        print(List.get(list1, 2));  // Should print 1

        // Test concat
        print("--- Testing concat() ---");
        int list2 = List.new();
        List.push(list2, 10);
        List.push(list2, 20);
        List.push(list2, 30);

        int list3 = List.new();
        List.push(list3, 40);
        List.push(list3, 50);

        int list4 = List.concat(list2, list3);
        int len4 = List.len(list4);
        print(len4);  // Should print 5
        print(List.get(list4, 0));  // Should print 10
        print(List.get(list4, 4));  // Should print 50

        // Test slice
        print("--- Testing slice() ---");
        int list5 = List.new();
        int i = 0;
        while (i < 10) {
            List.push(list5, i);
            i = i + 1;
        }

        int list6 = List.slice(list5, 2, 7);
        int len6 = List.len(list6);
        print(len6);  // Should print 5
        print(List.get(list6, 0));  // Should print 2
        print(List.get(list6, 4));  // Should print 6

        // Test sort
        print("--- Testing sort() ---");
        int list9 = List.new();
        List.push(list9, 64);
        List.push(list9, 34);
        List.push(list9, 25);
        List.push(list9, 12);
        List.push(list9, 22);

        List.sort(list9);
        print(List.get(list9, 0));  // Should print 12
        print(List.get(list9, 1));  // Should print 22
        print(List.get(list9, 4));  // Should print 64

        // Test unique
        print("--- Testing unique() ---");
        int list10 = List.new();
        List.push(list10, 1);
        List.push(list10, 2);
        List.push(list10, 2);
        List.push(list10, 3);
        List.push(list10, 1);

        int lenBefore = List.len(list10);
        print(lenBefore);  // Should print 5
        List.unique(list10);
        int lenAfter = List.len(list10);
        print(lenAfter);  // Should print 3 (unique values: 1, 2, 3)

        print("=== All tests completed! ===");
    }
}
