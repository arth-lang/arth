package test.native;

module Main {
    public static void main() {
        var f = fn(int a0, int a1, int a2, int a3, int a4, int a5, int a6, int a7, int a8) {
            return a0 + a1 + a2 + a3 + a4 + a5 + a6 + a7 + a8;
        };

        int result = f(1, 2, 3, 4, 5, 6, 7, 8, 9);
        if (result == 45) {
            println("PHASE1_CLOSURE_OK");
        } else {
            println("PHASE1_CLOSURE_BAD");
        }
    }
