package conformance;

// @spec: spec.md §5 - Control flow statements
// @expect: pass
// @description: Validates control flow parsing (if, while, for, switch)

module Main {
    public static void main() {
        // If-else
        Int x = 10;
        if (x > 5) {
            x = x + 1;
        }

        // If-else-if chain
        if (x > 20) {
            x = 1;
        } else if (x > 10) {
            x = 2;
        } else {
            x = 3;
        }

        // While loop
        Int counter = 0;
        while (counter < 5) {
            counter = counter + 1;
        }

        // For loop (C-style)
        for (Int i = 0; i < 10; i = i + 1) {
            counter = counter + i;
        }

        // For loop with break
        for (Int i = 0; i < 100; i = i + 1) {
            if (i > 5) {
                break;
            }
        }

        // For loop with continue
        for (Int i = 0; i < 10; i = i + 1) {
            if (i == 5) {
                continue;
            }
            counter = counter + 1;
        }

        // Switch with cases
        Int val = 2;
        switch (val) {
            case 1: {
                x = 10;
            }
            case 2: {
                x = 20;
            }
            case 3: {
                x = 30;
            }
            default: {
                x = 0;
            }
        }

        // Nested control flow
        for (Int i = 0; i < 3; i = i + 1) {
            for (Int j = 0; j < 3; j = j + 1) {
                if (i == j) {
                    continue;
                }
                counter = counter + 1;
            }
        }

        println("control_flow: pass");
    }
}
