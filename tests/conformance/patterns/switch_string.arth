package conformance;

// @spec: spec.md §13 - Pattern matching on strings
// @expect: pass
// @description: Validates switch on string values

module Main {
    public static void main() {
        String method = "GET";
        Int handler = 0;

        // Switch on string
        switch (method) {
            case "GET": {
                handler = 1;
            }
            case "POST": {
                handler = 2;
            }
            case "PUT": {
                handler = 3;
            }
            case "DELETE": {
                handler = 4;
            }
            default: {
                handler = 0;
            }
        }

        // String comparison in switch
        String env = "production";
        Bool debug = false;
        switch (env) {
            case "development": {
                debug = true;
            }
            case "staging": {
                debug = true;
            }
            case "production": {
                debug = false;
            }
            default: {
                debug = false;
            }
        }

        println("switch_string: pass");
    }
}
