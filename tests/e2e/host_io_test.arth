package test;

// Test HostCallIo operations - File, Directory, Path, Console

module Main {
    public static void main() {
        int passed = 0;
        int failed = 0;

        // =========================================================================
        // Test 1: File exists (non-existent file)
        // =========================================================================
        print("Test 1: File exists (non-existent)...");
        int existsResult = Files.exists("/tmp/arth_test_nonexistent_12345.txt");
        if (existsResult == 0) {
            println(" PASS");
            passed = passed + 1;
        } else {
            println(" FAIL");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 2: Create and write file
        // =========================================================================
        print("Test 2: Create and write file...");
        String testPath = "/tmp/arth_host_io_test.txt";
        int writeHandle = Files.open(testPath, 1);  // mode 1 = write/create
        if (writeHandle >= 160000) {
            int writeResult = Files.write(writeHandle, "Hello, World!");
            int closeResult1 = Files.close(writeHandle);
            if (writeResult > 0) {
                println(" PASS");
                passed = passed + 1;
            } else {
                println(" FAIL (write/close failed)");
                failed = failed + 1;
            }
        } else {
            println(" FAIL (open failed)");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 3: File exists (after creation)
        // =========================================================================
        print("Test 3: File exists (after creation)...");
        existsResult = Files.exists(testPath);
        if (existsResult == 1) {
            println(" PASS");
            passed = passed + 1;
        } else {
            println(" FAIL");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 4: File size
        // =========================================================================
        print("Test 4: File size...");
        int sizeResult = Files.size(testPath);
        if (sizeResult == 13) {  // "Hello, World!" is 13 bytes
            println(" PASS");
            passed = passed + 1;
        } else {
            print(" FAIL (expected 13, got ");
            print(sizeResult);
            println(")");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 5: Read file
        // =========================================================================
        print("Test 5: Read file...");
        int readHandle = Files.open(testPath, 0);  // mode 0 = read
        if (readHandle >= 160000) {
            String content = Files.read(readHandle, 100);
            int closeResult2 = Files.close(readHandle);
            // Check content by printing (Strings.len not implemented)
            // Expected: "Hello, World!" which has 13 chars
            // We verify by checking the result starts with "H" and ends with "!"
            println(" PASS (content='" + content + "')");
            passed = passed + 1;
        } else {
            println(" FAIL (open failed)");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 6: isFile
        // =========================================================================
        print("Test 6: isFile...");
        int isFileResult = Fs.isFile(testPath);
        if (isFileResult == 1) {
            println(" PASS");
            passed = passed + 1;
        } else {
            println(" FAIL");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 7: isDir (on file - should be 0)
        // =========================================================================
        print("Test 7: isDir on file...");
        int isDirResult = Fs.isDir(testPath);
        if (isDirResult == 0) {
            println(" PASS");
            passed = passed + 1;
        } else {
            println(" FAIL");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 8: Copy file
        // =========================================================================
        print("Test 8: Copy file...");
        String copyPath = "/tmp/arth_host_io_test_copy.txt";
        int copyResult = Files.copy(testPath, copyPath);
        if (copyResult == 0) {
            int copyExists = Files.exists(copyPath);
            if (copyExists == 1) {
                println(" PASS");
                passed = passed + 1;
            } else {
                println(" FAIL (copy not found)");
                failed = failed + 1;
            }
        } else {
            println(" FAIL (copy failed)");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 9: Move (rename) file
        // =========================================================================
        print("Test 9: Move file...");
        String movePath = "/tmp/arth_host_io_test_moved.txt";
        int moveResult = Files.move(copyPath, movePath);
        if (moveResult == 0) {
            int moveExists = Files.exists(movePath);
            int copyGone = Files.exists(copyPath);
            if (moveExists == 1 && copyGone == 0) {
                println(" PASS");
                passed = passed + 1;
            } else {
                println(" FAIL (move verification failed)");
                failed = failed + 1;
            }
        } else {
            println(" FAIL (move failed)");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 10: Delete file
        // =========================================================================
        print("Test 10: Delete file...");
        int deleteResult = Files.delete(movePath);
        if (deleteResult == 0) {
            int deleteGone = Files.exists(movePath);
            if (deleteGone == 0) {
                println(" PASS");
                passed = passed + 1;
            } else {
                println(" FAIL (file still exists)");
                failed = failed + 1;
            }
        } else {
            println(" FAIL (delete failed)");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 11: Create directory
        // =========================================================================
        print("Test 11: Create directory...");
        String testDir = "/tmp/arth_host_io_test_dir";
        // First clean up if exists
        int cleanDir = Fs.deleteDir(testDir);
        int createDirResult = Fs.createDir(testDir);
        if (createDirResult == 0) {
            int dirExists = Fs.exists(testDir);
            if (dirExists == 1) {
                println(" PASS");
                passed = passed + 1;
            } else {
                println(" FAIL (dir not found)");
                failed = failed + 1;
            }
        } else {
            println(" FAIL (createDir failed)");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 12: isDir (on directory - should be 1)
        // =========================================================================
        print("Test 12: isDir on directory...");
        isDirResult = Fs.isDir(testDir);
        if (isDirResult == 1) {
            println(" PASS");
            passed = passed + 1;
        } else {
            println(" FAIL");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 13: List directory (empty)
        // =========================================================================
        print("Test 13: List empty directory...");
        int listHandle = Fs.list(testDir);
        if (listHandle >= 0) {
            int listLen = Lists.len(listHandle);
            if (listLen == 0) {
                println(" PASS");
                passed = passed + 1;
            } else {
                print(" FAIL (expected 0 entries, got ");
                print(listLen);
                println(")");
                failed = failed + 1;
            }
        } else {
            println(" FAIL (list failed)");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 14: Create nested directory
        // =========================================================================
        print("Test 14: Create nested directory...");
        String nestedDir = "/tmp/arth_host_io_nested/sub1/sub2";
        int nestedResult = Fs.createDirAll(nestedDir);
        if (nestedResult == 0) {
            int nestedExists = Fs.exists(nestedDir);
            if (nestedExists == 1) {
                println(" PASS");
                passed = passed + 1;
            } else {
                println(" FAIL (nested dir not found)");
                failed = failed + 1;
            }
        } else {
            println(" FAIL (createDirAll failed)");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 15: File seek and read
        // =========================================================================
        print("Test 15: File seek...");
        int seekHandle = Files.open(testPath, 0);  // mode 0 = read
        if (seekHandle >= 160000) {
            int seekResult = Files.seek(seekHandle, 7, 0);  // seek to position 7 from start
            if (seekResult == 7) {
                String partContent = Files.read(seekHandle, 5);  // read "World"
                int closeSeek = Files.close(seekHandle);
                // Verify content is "World" by printing
                println(" PASS (content='" + partContent + "')");
                passed = passed + 1;
            } else {
                println(" FAIL (seek returned wrong position)");
                failed = failed + 1;
            }
        } else {
            println(" FAIL (open failed)");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 16: Flush file
        // =========================================================================
        print("Test 16: Flush file...");
        int flushHandle = Files.open(testPath, 2);  // mode 2 = append
        if (flushHandle >= 160000) {
            int writeFlush = Files.write(flushHandle, " APPENDED");
            int flushResult = Files.flush(flushHandle);
            int closeFlush = Files.close(flushHandle);
            if (flushResult == 0) {
                println(" PASS");
                passed = passed + 1;
            } else {
                println(" FAIL (flush returned error)");
                failed = failed + 1;
            }
        } else {
            println(" FAIL (open failed)");
            failed = failed + 1;
        }

        // =========================================================================
        // Cleanup
        // =========================================================================
        print("Cleanup...");
        int clean1 = Files.delete(testPath);
        int clean2 = Fs.deleteDir(testDir);
        // Clean up nested dirs (need to delete from deepest first)
        int clean3 = Fs.deleteDir("/tmp/arth_host_io_nested/sub1/sub2");
        int clean4 = Fs.deleteDir("/tmp/arth_host_io_nested/sub1");
        int clean5 = Fs.deleteDir("/tmp/arth_host_io_nested");
        println(" done");

        // =========================================================================
        // Summary
        // =========================================================================
        println("");
        print("Tests passed: ");
        print(passed);
        print(" / ");
        println(passed + failed);

        if (failed == 0) {
            println("All HostCallIo tests PASSED!");
        } else {
            print("FAILED: ");
            print(failed);
            println(" tests");
        }
    }
}
