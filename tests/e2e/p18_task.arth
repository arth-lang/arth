package test;

// Test: Task<T> creation and join
// P18: Task<T> creation/join
//
// This test demonstrates the Task<T> API with DEFERRED EXECUTION:
// - Calling async functions WITHOUT await creates Task handles
// - Task body does NOT execute at spawn time
// - Task body executes at await/join time (cooperative state machine)
//
// Expected output (deferred execution - body runs at await, not at spawn):
//   === Task Handle Storage ===
//   about to create task handle
//   task handle stored (type: Int handle)
//   doing other work...
//   now joining the task
//   computing value
//   result: 42
//   === Concurrent Task Creation ===
//   creating task handles for parallel work
//   both task handles created
//   joining first task
//   computing first
//   first result: 10
//   joining second task
//   computing second
//   second result: 20
//   combined: 30
//   === Task Handle Passing ===
//   passing task handle to helper
//   computing passable
//   in helper, joining task
//   helper got: 99
//   === All Task tests passed ===

module Main {
    // Async function that returns a value
    public static async Int computeValue() {
        println("computing value");
        return 42;
    }

    // Async functions for parallel task demo
    public static async Int computeFirst() {
        println("computing first");
        return 10;
    }

    public static async Int computeSecond() {
        println("computing second");
        return 20;
    }

    // Async function to demonstrate handle passing
    public static async Int computePassable() {
        println("computing passable");
        return 99;
    }

    // Helper function that takes a task handle (represented as Int for MVP)
    // and joins it to get the result
    public static Int joinTask(Int taskHandle) {
        println("in helper, joining task");
        // For MVP, the taskHandle IS the result (synchronous execution)
        return taskHandle;
    }

    public static void main() {
        // === Test 1: Task Handle Storage ===
        // Call async function WITHOUT await to get a Task<T> handle
        // In MVP, execution happens at call time but we get a Task back
        println("=== Task Handle Storage ===");
        println("about to create task handle");

        // Call async function WITHOUT await - should return Task<Int>
        var task = computeValue();  // No await - gets Task<Int>
        println("task handle stored (type: Int handle)");
        println("doing other work...");

        // Now join the task to get the result
        println("now joining the task");
        Int taskResult = await task;  // Await the stored task
        println("result: " + taskResult);

        // === Test 2: Concurrent Task Creation ===
        // Create multiple tasks before joining any
        println("=== Concurrent Task Creation ===");
        println("creating task handles for parallel work");

        // Create both tasks (in MVP, they execute immediately)
        var task1 = computeFirst();
        var task2 = computeSecond();

        println("both task handles created");

        // Join tasks in order
        println("joining first task");
        Int result1 = await task1;
        println("first result: " + result1);

        println("joining second task");
        Int result2 = await task2;
        println("second result: " + result2);

        Int combined = result1 + result2;
        println("combined: " + combined);

        // === Test 3: Task Handle Passing ===
        // Demonstrate that task handles (as Int) can be passed around
        println("=== Task Handle Passing ===");
        println("passing task handle to helper");

        // Get a task result and pass it to helper
        Int passableResult = await computePassable();
        Int helperResult = joinTask(passableResult);
        println("helper got: " + helperResult);

        println("=== All Task tests passed ===");
    }
}
