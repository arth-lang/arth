package test;

// Test: C17 - Sendable Auto-Derive
//
// This test verifies that Sendable is automatically derived for types:
// - Structs with all Sendable fields → auto Sendable
// - Enums with all Sendable variant payloads → auto Sendable
// - Nested structs (transitive derivation)
// - @notSendable attribute blocks derivation
// - @notShareable attribute blocks derivation
// - Structs containing non-Sendable fields → NOT Sendable

// ============================================
// Test 1: Simple struct with primitive fields
// Should be auto-derived as Sendable
// ============================================
struct Point {
    Int x;
    Int y;
}

// ============================================
// Test 2: Struct with multiple primitive types
// Should be auto-derived as Sendable
// ============================================
struct UserData {
    Int id;
    String name;
    Bool active;
    Float score;
}

// ============================================
// Test 3: Nested struct (transitive derivation)
// Rectangle is Sendable because Point is Sendable
// ============================================
struct Rectangle {
    Point topLeft;
    Point bottomRight;
}

// ============================================
// Test 4: Deep nesting (3 levels)
// All levels should be auto-derived
// ============================================
struct Level1 { Int value; }
struct Level2 { Level1 inner; }
struct Level3 { Level2 inner; }

// ============================================
// Test 5: Enum with unit variants
// Should be auto-derived as Sendable
// ============================================
enum Status {
    Pending,
    Running,
    Completed,
    Failed
}

// ============================================
// Test 6: Enum with primitive payloads
// Should be auto-derived as Sendable
// ============================================
enum Result {
    Ok(Int),
    Err(String)
}

// ============================================
// Test 7: Enum with Sendable struct payload
// Should be auto-derived as Sendable
// ============================================
enum Message {
    Empty,
    Data(Point),
    Text(String)
}

// ============================================
// Test 8: @notSendable opt-out
// This struct has all primitive fields but explicitly opts out
// ============================================
@notSendable
struct UnsafeHandle {
    Int rawPointer;  // Primitive, but we don't want this to be Sendable
}

// ============================================
// Test 9: @notShareable opt-out
// This struct can be sent but not shared
// ============================================
@notShareable
struct ExclusiveResource {
    Int handle;
    String name;
}

// ============================================
// Test 10: Both opt-outs
// ============================================
@notSendable
@notShareable
struct ThreadLocalData {
    Int threadId;
    String context;
}

// ============================================
// Test 11: Struct containing non-Sendable type
// Should NOT be auto-derived as Sendable
// ============================================
struct ContainsUnsafe {
    Int id;
    UnsafeHandle handle;  // UnsafeHandle is @notSendable
}

// ============================================
// Test 12: Struct with multiple fields, one non-Sendable
// ============================================
struct MixedFields {
    Int x;
    String y;
    UnsafeHandle z;  // This makes the whole struct not Sendable
}

// ============================================
// Test 13: Empty struct (no fields)
// Should be Sendable by default
// ============================================
struct EmptyStruct {
}

// ============================================
// Test 14: Struct with single field
// ============================================
struct SingleField {
    Int value;
}

// ============================================
// Modules for testing
// ============================================

module PointFns {
    public Point new(Int x, Int y) {
        return Point { x: x, y: y };
    }
}

module RectangleFns {
    public Rectangle new(Point tl, Point br) {
        return Rectangle { topLeft: tl, bottomRight: br };
    }
}

module UserDataFns {
    public UserData new(Int id, String name, Bool active, Float score) {
        return UserData { id: id, name: name, active: active, score: score };
    }
}

module Level3Fns {
    public Level3 new(Int value) {
        Level1 l1 = Level1 { value: value };
        Level2 l2 = Level2 { inner: l1 };
        return Level3 { inner: l2 };
    }
}

module UnsafeHandleFns {
    public UnsafeHandle new(Int ptr) {
        return UnsafeHandle { rawPointer: ptr };
    }
}

module ExclusiveResourceFns {
    public ExclusiveResource new(Int handle, String name) {
        return ExclusiveResource { handle: handle, name: name };
    }
}

module ContainsUnsafeFns {
    public ContainsUnsafe new(Int id, UnsafeHandle h) {
        return ContainsUnsafe { id: id, handle: h };
    }
}

module Executor {
    // Executor intrinsics for parallel task testing
}

module Actor {
    // Actor intrinsics for message passing testing
}

module Main {
    public static void main() {
        println("=== C17: Sendable Auto-Derive ===");

        // Initialize thread pool
        println("Initializing pool with 4 threads...");
        Int initResult = Executor.init(4);
        println("Pool initialized: " + initResult);

        Int resetResult = Executor.resetStats();

        Int totalTests = 0;
        Int passedTests = 0;

        // ========================================
        // Test 1: Simple Point struct
        // ========================================
        println("=== Test 1: Simple Point Struct ===");
        totalTests = totalTests + 1;

        Point p = PointFns.new(10, 20);
        println("Point created: x=" + p.x + ", y=" + p.y);

        // Use actor to verify Sendable (messages must be Sendable)
        Int actor1 = Actor.create(10);
        Int s1 = Actor.send(actor1, p.x);  // Int is Sendable
        Int s2 = Actor.send(actor1, p.y);
        Int r1 = Actor.recv(actor1);
        Int r2 = Actor.recv(actor1);

        Int test1Pass = 0;
        if (r1 == 10) {
            if (r2 == 20) {
                println("Test 1 (simple struct auto-derive): PASS");
                test1Pass = 1;
                passedTests = passedTests + 1;
            }
        }
        if (test1Pass == 0) {
            println("Test 1 FAIL: expected 10, 20");
        }

        // ========================================
        // Test 2: UserData with multiple types
        // ========================================
        println("=== Test 2: Multiple Primitive Types ===");
        totalTests = totalTests + 1;

        UserData user = UserDataFns.new(42, "Alice", true, 3.14);
        println("UserData: id=" + user.id + ", name=" + user.name);

        Int actor2 = Actor.create(10);
        Int us1 = Actor.send(actor2, user.id);
        Int ur1 = Actor.recv(actor2);

        Int test2Pass = 0;
        if (ur1 == 42) {
            println("Test 2 (multiple primitive types): PASS");
            test2Pass = 1;
            passedTests = passedTests + 1;
        } else {
            println("Test 2 FAIL: expected 42, got " + ur1);
        }

        // ========================================
        // Test 3: Nested struct (Rectangle)
        // ========================================
        println("=== Test 3: Nested Struct ===");
        totalTests = totalTests + 1;

        Point tl = PointFns.new(0, 0);
        Point br = PointFns.new(100, 50);
        Rectangle rect = RectangleFns.new(tl, br);
        println("Rectangle: tl=(" + rect.topLeft.x + "," + rect.topLeft.y + ")");

        Int actor3 = Actor.create(10);
        Int rs1 = Actor.send(actor3, rect.topLeft.x);
        Int rs2 = Actor.send(actor3, rect.bottomRight.x);
        Int rr1 = Actor.recv(actor3);
        Int rr2 = Actor.recv(actor3);

        Int test3Pass = 0;
        if (rr1 == 0) {
            if (rr2 == 100) {
                println("Test 3 (nested struct auto-derive): PASS");
                test3Pass = 1;
                passedTests = passedTests + 1;
            }
        }
        if (test3Pass == 0) {
            println("Test 3 FAIL");
        }

        // ========================================
        // Test 4: Deep nesting (3 levels)
        // ========================================
        println("=== Test 4: Deep Nesting ===");
        totalTests = totalTests + 1;

        Level3 l3 = Level3Fns.new(999);
        println("Level3 value: " + l3.inner.inner.value);

        Int actor4 = Actor.create(10);
        Int ls1 = Actor.send(actor4, l3.inner.inner.value);
        Int lr1 = Actor.recv(actor4);

        Int test4Pass = 0;
        if (lr1 == 999) {
            println("Test 4 (deep nesting auto-derive): PASS");
            test4Pass = 1;
            passedTests = passedTests + 1;
        } else {
            println("Test 4 FAIL: expected 999, got " + lr1);
        }

        // ========================================
        // Test 5: Enum with unit variants
        // ========================================
        println("=== Test 5: Enum Unit Variants ===");
        totalTests = totalTests + 1;

        Status pending = Status.Pending;
        Status completed = Status.Completed;
        println("Created Status enums");

        // Can use enums in actor messaging
        Int actor5 = Actor.create(10);
        Int es1 = Actor.send(actor5, 1);  // Placeholder for enum
        Int er1 = Actor.recv(actor5);

        Int test5Pass = 0;
        if (er1 == 1) {
            println("Test 5 (enum unit variants): PASS");
            test5Pass = 1;
            passedTests = passedTests + 1;
        } else {
            println("Test 5 FAIL");
        }

        // ========================================
        // Test 6: Enum with primitive payloads
        // ========================================
        println("=== Test 6: Enum Primitive Payloads ===");
        totalTests = totalTests + 1;

        Result ok = Result.Ok(42);
        Result err = Result.Err("error");
        println("Created Result enums");

        Int actor6 = Actor.create(10);
        Int ps1 = Actor.send(actor6, 42);  // Ok value
        Int pr1 = Actor.recv(actor6);

        Int test6Pass = 0;
        if (pr1 == 42) {
            println("Test 6 (enum primitive payloads): PASS");
            test6Pass = 1;
            passedTests = passedTests + 1;
        } else {
            println("Test 6 FAIL: expected 42, got " + pr1);
        }

        // ========================================
        // Test 7: Enum with struct payload
        // ========================================
        println("=== Test 7: Enum Struct Payload ===");
        totalTests = totalTests + 1;

        Point mp = PointFns.new(5, 10);
        Message data = Message.Data(mp);
        println("Created Message.Data with Point");

        Int actor7 = Actor.create(10);
        Int ms1 = Actor.send(actor7, mp.x);
        Int ms2 = Actor.send(actor7, mp.y);
        Int mr1 = Actor.recv(actor7);
        Int mr2 = Actor.recv(actor7);

        Int test7Pass = 0;
        if (mr1 == 5) {
            if (mr2 == 10) {
                println("Test 7 (enum struct payload): PASS");
                test7Pass = 1;
                passedTests = passedTests + 1;
            }
        }
        if (test7Pass == 0) {
            println("Test 7 FAIL");
        }

        // ========================================
        // Test 8: @notSendable opt-out
        // The compile-time rejection is tested in typeck tests
        // Here we verify the struct still exists and works locally
        // ========================================
        println("=== Test 8: @notSendable Opt-Out ===");
        totalTests = totalTests + 1;

        UnsafeHandle uh = UnsafeHandleFns.new(12345);
        println("UnsafeHandle created: rawPointer=" + uh.rawPointer);

        // Verify the value locally (not across task boundaries)
        Int test8Pass = 0;
        if (uh.rawPointer == 12345) {
            println("Test 8 (@notSendable struct exists): PASS");
            test8Pass = 1;
            passedTests = passedTests + 1;
        } else {
            println("Test 8 FAIL");
        }

        // ========================================
        // Test 9: @notShareable opt-out
        // ========================================
        println("=== Test 9: @notShareable Opt-Out ===");
        totalTests = totalTests + 1;

        ExclusiveResource res = ExclusiveResourceFns.new(999, "exclusive");
        println("ExclusiveResource: handle=" + res.handle);

        Int test9Pass = 0;
        if (res.handle == 999) {
            println("Test 9 (@notShareable struct exists): PASS");
            test9Pass = 1;
            passedTests = passedTests + 1;
        } else {
            println("Test 9 FAIL");
        }

        // ========================================
        // Test 10: Both @notSendable and @notShareable
        // ========================================
        println("=== Test 10: Both Opt-Outs ===");
        totalTests = totalTests + 1;

        ThreadLocalData tld = ThreadLocalData { threadId: 42, context: "local" };
        println("ThreadLocalData: threadId=" + tld.threadId);

        Int test10Pass = 0;
        if (tld.threadId == 42) {
            println("Test 10 (both opt-outs): PASS");
            test10Pass = 1;
            passedTests = passedTests + 1;
        } else {
            println("Test 10 FAIL");
        }

        // ========================================
        // Test 11: Transitive non-Sendable
        // ContainsUnsafe contains UnsafeHandle which is @notSendable
        // So ContainsUnsafe should also not be Sendable
        // (Compile-time verification in typeck tests)
        // ========================================
        println("=== Test 11: Transitive Non-Sendable ===");
        totalTests = totalTests + 1;

        UnsafeHandle uh2 = UnsafeHandleFns.new(54321);
        ContainsUnsafe cu = ContainsUnsafeFns.new(1, uh2);
        println("ContainsUnsafe: id=" + cu.id + ", handle.ptr=" + cu.handle.rawPointer);

        Int test11Pass = 0;
        if (cu.id == 1) {
            if (cu.handle.rawPointer == 54321) {
                println("Test 11 (transitive non-Sendable): PASS");
                test11Pass = 1;
                passedTests = passedTests + 1;
            }
        }
        if (test11Pass == 0) {
            println("Test 11 FAIL");
        }

        // ========================================
        // Test 12: Empty struct
        // ========================================
        println("=== Test 12: Empty Struct ===");
        totalTests = totalTests + 1;

        EmptyStruct es = EmptyStruct {};
        println("EmptyStruct created");

        println("Test 12 (empty struct): PASS");
        passedTests = passedTests + 1;

        // ========================================
        // Test 13: Parallel spawn with derived Sendable
        // ========================================
        println("=== Test 13: Parallel Spawn ===");
        totalTests = totalTests + 1;

        // Spawn tasks with fibonacci (args must be Sendable)
        Int t1 = Executor.spawnWithArg(2, 8);   // fib(8) = 21
        Int t2 = Executor.spawnWithArg(2, 9);   // fib(9) = 34
        Int t3 = Executor.spawnWithArg(2, 10);  // fib(10) = 55

        Int j1 = Executor.join(t1);
        Int j2 = Executor.join(t2);
        Int j3 = Executor.join(t3);

        Int fibSum = j1 + j2 + j3;
        println("Fibonacci results: " + j1 + ", " + j2 + ", " + j3);
        println("Sum: " + fibSum);

        Int test13Pass = 0;
        if (fibSum == 110) { // 21 + 34 + 55 = 110
            println("Test 13 (parallel spawn): PASS");
            test13Pass = 1;
            passedTests = passedTests + 1;
        } else {
            println("Test 13 FAIL: expected 110, got " + fibSum);
        }

        // ========================================
        // Summary
        // ========================================
        println("=== Summary ===");
        println("Passed: " + passedTests + "/" + totalTests);

        if (passedTests == totalTests) {
            println("ALL TESTS PASSED");
        } else {
            println("SOME TESTS FAILED");
        }
    }
}
