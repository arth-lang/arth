package test;

// Test: String operations
// Expected output:
//   Hello
//   Hello World
//   Hello World!

module Main {
    public static void main() {
        String s1 = "Hello";
        String s2 = "World";

        println(s1);
        println(s1 + " " + s2);
        println(s1 + " " + s2 + "!");
    }
}
