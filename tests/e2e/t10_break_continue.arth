package test;

// Test: break and continue
// Expected output:
//   1
//   3
//   5
//   stopped

module Main {
    public static void main() {
        Int i = 0;
        while (i < 10) {
            i = i + 1;
            if (i % 2 == 0) {
                continue;
            }
            if (i > 5) {
                break;
            }
            println(i);
        }
        println("stopped");
    }
}
