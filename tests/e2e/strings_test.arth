package test;

// Test String intrinsic operations

module Main {
    public static void main() {
        int passed = 0;
        int failed = 0;

        // =========================================================================
        // Test 1: Strings.len
        // =========================================================================
        print("Test 1: Strings.len...");
        String s1 = "Hello";
        int len1 = Strings.len(s1);
        if (len1 == 5) {
            println(" PASS");
            passed = passed + 1;
        } else {
            print(" FAIL (expected 5, got ");
            print(len1);
            println(")");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 2: Strings.len empty string
        // =========================================================================
        print("Test 2: Strings.len empty...");
        String empty = "";
        int lenEmpty = Strings.len(empty);
        if (lenEmpty == 0) {
            println(" PASS");
            passed = passed + 1;
        } else {
            print(" FAIL (expected 0, got ");
            print(lenEmpty);
            println(")");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 3: Strings.substring
        // =========================================================================
        print("Test 3: Strings.substring...");
        String s2 = "Hello, World!";
        String sub = Strings.substring(s2, 0, 5);
        // Verify by checking length and printing
        int subLen = Strings.len(sub);
        if (subLen == 5) {
            print(" PASS (got '");
            print(sub);
            println("')");
            passed = passed + 1;
        } else {
            print(" FAIL (len=");
            print(subLen);
            print(", got '");
            print(sub);
            println("')");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 4: Strings.indexOf
        // =========================================================================
        print("Test 4: Strings.indexOf...");
        int idx1 = Strings.indexOf(s2, "World");
        if (idx1 == 7) {
            println(" PASS");
            passed = passed + 1;
        } else {
            print(" FAIL (expected 7, got ");
            print(idx1);
            println(")");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 5: Strings.indexOf not found
        // =========================================================================
        print("Test 5: Strings.indexOf not found...");
        int idx2 = Strings.indexOf(s2, "xyz");
        if (idx2 == -1) {
            println(" PASS");
            passed = passed + 1;
        } else {
            print(" FAIL (expected -1, got ");
            print(idx2);
            println(")");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 6: Strings.lastIndexOf
        // =========================================================================
        print("Test 6: Strings.lastIndexOf...");
        String s3 = "hello hello";
        int lastIdx = Strings.lastIndexOf(s3, "hello");
        if (lastIdx == 6) {
            println(" PASS");
            passed = passed + 1;
        } else {
            print(" FAIL (expected 6, got ");
            print(lastIdx);
            println(")");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 7: Strings.startsWith
        // =========================================================================
        print("Test 7: Strings.startsWith...");
        int starts = Strings.startsWith(s2, "Hello");
        if (starts == 1) {
            println(" PASS");
            passed = passed + 1;
        } else {
            println(" FAIL");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 8: Strings.startsWith false
        // =========================================================================
        print("Test 8: Strings.startsWith false...");
        int startsF = Strings.startsWith(s2, "World");
        if (startsF == 0) {
            println(" PASS");
            passed = passed + 1;
        } else {
            println(" FAIL");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 9: Strings.endsWith
        // =========================================================================
        print("Test 9: Strings.endsWith...");
        int ends = Strings.endsWith(s2, "World!");
        if (ends == 1) {
            println(" PASS");
            passed = passed + 1;
        } else {
            println(" FAIL");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 10: Strings.trim
        // =========================================================================
        print("Test 10: Strings.trim...");
        String padded = "  hello  ";
        String trimmed = Strings.trim(padded);
        int trimLen = Strings.len(trimmed);
        if (trimLen == 5) {
            print(" PASS (got '");
            print(trimmed);
            println("')");
            passed = passed + 1;
        } else {
            print(" FAIL (len=");
            print(trimLen);
            println(")");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 11: Strings.toLower
        // =========================================================================
        print("Test 11: Strings.toLower...");
        String upper = "HELLO";
        String lower = Strings.toLower(upper);
        // Verify by checking it contains 'h' (72 -> 104 lowercase)
        int chFirst = Strings.charAt(lower, 0);
        if (chFirst == 104) {  // 'h' = 104
            print(" PASS (got '");
            print(lower);
            println("')");
            passed = passed + 1;
        } else {
            print(" FAIL (first char=");
            print(chFirst);
            println(")");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 12: Strings.toUpper
        // =========================================================================
        print("Test 12: Strings.toUpper...");
        String lowerStr = "hello";
        String upperStr = Strings.toUpper(lowerStr);
        // Verify by checking first char is 'H' (72)
        int chUpperFirst = Strings.charAt(upperStr, 0);
        if (chUpperFirst == 72) {  // 'H' = 72
            print(" PASS (got '");
            print(upperStr);
            println("')");
            passed = passed + 1;
        } else {
            print(" FAIL (first char=");
            print(chUpperFirst);
            println(")");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 13: Strings.replace
        // =========================================================================
        print("Test 13: Strings.replace...");
        String original = "foo bar foo";
        String replaced = Strings.replace(original, "foo", "baz");
        // Verify by checking indexOf "baz" returns 0
        int bazIdx = Strings.indexOf(replaced, "baz");
        if (bazIdx == 0) {
            print(" PASS (got '");
            print(replaced);
            println("')");
            passed = passed + 1;
        } else {
            print(" FAIL (indexOf baz=");
            print(bazIdx);
            println(")");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 14: Strings.charAt
        // =========================================================================
        print("Test 14: Strings.charAt...");
        int ch = Strings.charAt(s1, 0);
        if (ch == 72) {  // 'H' = 72
            println(" PASS");
            passed = passed + 1;
        } else {
            print(" FAIL (expected 72, got ");
            print(ch);
            println(")");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 15: Strings.contains
        // =========================================================================
        print("Test 15: Strings.contains...");
        int contains = Strings.contains(s2, "World");
        if (contains == 1) {
            println(" PASS");
            passed = passed + 1;
        } else {
            println(" FAIL");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 16: Strings.contains false
        // =========================================================================
        print("Test 16: Strings.contains false...");
        int containsF = Strings.contains(s2, "xyz");
        if (containsF == 0) {
            println(" PASS");
            passed = passed + 1;
        } else {
            println(" FAIL");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 17: Strings.repeat
        // =========================================================================
        print("Test 17: Strings.repeat...");
        String repeated = Strings.repeat("ab", 3);
        int repeatLen = Strings.len(repeated);
        if (repeatLen == 6) {
            print(" PASS (got '");
            print(repeated);
            println("')");
            passed = passed + 1;
        } else {
            print(" FAIL (len=");
            print(repeatLen);
            println(")");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 18: Strings.parseInt
        // =========================================================================
        print("Test 18: Strings.parseInt...");
        int parsed = Strings.parseInt("42");
        if (parsed == 42) {
            println(" PASS");
            passed = passed + 1;
        } else {
            print(" FAIL (expected 42, got ");
            print(parsed);
            println(")");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 19: Strings.parseFloat
        // =========================================================================
        print("Test 19: Strings.parseFloat...");
        float pf = Strings.parseFloat("3.14");
        // Cast to int to verify parsing worked (3.14 -> 3)
        int pfInt = (int)pf;
        if (pfInt == 3) {
            println(" PASS");
            passed = passed + 1;
        } else {
            print(" FAIL (got ");
            print(pf);
            println(")");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 20: Strings.fromInt
        // =========================================================================
        print("Test 20: Strings.fromInt...");
        String fromI = Strings.fromInt(123);
        int fromILen = Strings.len(fromI);
        if (fromILen == 3) {
            print(" PASS (got '");
            print(fromI);
            println("')");
            passed = passed + 1;
        } else {
            print(" FAIL (len=");
            print(fromILen);
            println(")");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 21: Strings.fromFloat
        // =========================================================================
        print("Test 21: Strings.fromFloat...");
        String fromF = Strings.fromFloat(3.5);
        // Float conversion may produce "3.5" or "3.5000..."
        int containsNum = Strings.contains(fromF, "3.5");
        if (containsNum == 1) {
            print(" PASS (got '");
            print(fromF);
            println("')");
            passed = passed + 1;
        } else {
            print(" FAIL (got '");
            print(fromF);
            println("')");
            failed = failed + 1;
        }

        // =========================================================================
        // Test 22: Strings.split
        // =========================================================================
        print("Test 22: Strings.split...");
        String csv = "a,b,c";
        int listHandle = Strings.split(csv, ",");
        int listLen = List.len(listHandle);
        if (listLen == 3) {
            println(" PASS");
            passed = passed + 1;
        } else {
            print(" FAIL (expected 3 parts, got ");
            print(listLen);
            println(")");
            failed = failed + 1;
        }

        // =========================================================================
        // Summary
        // =========================================================================
        println("");
        print("Tests passed: ");
        print(passed);
        print(" / ");
        println(passed + failed);

        if (failed == 0) {
            println("All Strings tests PASSED!");
        } else {
            print("FAILED: ");
            print(failed);
            println(" tests");
        }
    }
}
