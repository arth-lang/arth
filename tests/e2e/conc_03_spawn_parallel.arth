        // Batch 81-90
        Int p81 = Executor.spawnWithArg(workType, fibArg);
        Int p82 = Executor.spawnWithArg(workType, fibArg);
        Int p83 = Executor.spawnWithArg(workType, fibArg);
        Int p84 = Executor.spawnWithArg(workType, fibArg);
        Int p85 = Executor.spawnWithArg(workType, fibArg);
        Int p86 = Executor.spawnWithArg(workType, fibArg);
        Int p87 = Executor.spawnWithArg(workType, fibArg);
        Int p88 = Executor.spawnWithArg(workType, fibArg);
