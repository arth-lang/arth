        // Get work distribution stats
        println("=== Work Distribution Stats ===");
        Int workersUsed = Executor.activeExecutorCount();
        println("Workers that executed tasks: " + workersUsed);

        Int w0 = Executor.workerTaskCount(0);
        Int w1 = Executor.workerTaskCount(1);
        Int w2 = Executor.workerTaskCount(2);
        Int w3 = Executor.workerTaskCount(3);
        println("Worker 0 tasks: " + w0);
        println("Worker 1 tasks: " + w1);
        println("Worker 2 tasks: " + w2);
        println("Worker 3 tasks: " + w3);

        Int totalExecuted = w0 + w1 + w2 + w3;
        println("Total executed: " + totalExecuted);

        // Verification
        println("=== Speedup Analysis ===");

        // Expected parallel time for 100 tasks based on sequential 20 tasks
        // Sequential 20 tasks took seqElapsed ms
        // If perfect scaling, 100 tasks with 4 threads ≈ (100/4) * (seqElapsed/20) = 1.25 * seqElapsed
        // In practice, overhead means it will be higher

        // Calculate speedup: what would 100 sequential tasks take?
        // Estimated seq100 = seqElapsed * 5 (since seq was 20 tasks)
        Int estimatedSeq100 = seqElapsed * 5;
        println("Estimated sequential time for 100 tasks: " + estimatedSeq100 + " ms");

        Int speedupPct = 0;
        if (parElapsed > 0) {
            speedupPct = (estimatedSeq100 * 100) / parElapsed;
        }
        println("Speedup: " + speedupPct + "% (est_seq100/par * 100)");

        Int passCount = 0;

        // Check for at least 2x speedup
        if (speedupPct >= 200) {
            println("Speedup >= 2x: PASS (" + speedupPct + "%)");
            passCount = passCount + 1;
        } else {
            println("Speedup >= 2x: FAIL (" + speedupPct + "%)");
        }

        // Check parallel is faster than estimated sequential
        if (parElapsed < estimatedSeq100) {
            println("Parallel faster than sequential: PASS");
            passCount = passCount + 1;
        } else {
            println("Parallel faster than sequential: FAIL");
        }

        // Check all 100 tasks completed
        if (totalExecuted == 100) {
            println("All 100 tasks completed: PASS");
            passCount = passCount + 1;
        } else {
            println("All 100 tasks completed: FAIL (" + totalExecuted + ")");
        }

        // Check multiple workers participated
