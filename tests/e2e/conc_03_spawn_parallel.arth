package test;

// Test: C03 - Task Spawn to Pool
//
// This test verifies scalable task spawning:
// - Spawn 100 CPU-bound tasks (fibonacci)
// - With 4 threads, should complete ~4x faster than sequential
// - Measures wall-clock time to prove parallelism
// - Verifies work distribution across all workers

module Executor {
    // Executor intrinsics mapped to __arth_executor_* VM calls
}

module Instants {
    // Time measurement intrinsics
}

module Main {
    public static void main() {
        println("=== C03: Task Spawn to Pool ===");

        // Initialize thread pool with 4 threads
        println("Initializing pool with 4 threads...");
        Int initResult = Executor.init(4);
        println("Pool initialized: " + initResult);

        Int threadCount = Executor.threadCount();
        println("Thread count: " + threadCount);

        // Reset stats
        Int resetResult = Executor.resetStats();

        // Work parameters: type 2 = fibonacci
        Int workType = 2;
        Int fibArg = 30;

        println("=== Sequential Execution ===");
        println("Running 20 fib(30) tasks sequentially...");

        // Measure sequential time (20 tasks for reasonable time)
        Int seqStart = Instants.now();

        // Sequential: spawn + join one at a time
        Int s1 = Executor.spawnWithArg(workType, fibArg);
        Int rs1 = Executor.join(s1);
