package test;

import arth.*;

// Test: List operations via intrinsics
// Expected output:
//   len: 3
//   get 0: 10
//   get 1: 20
//   get 2: 30

module Main {
    public static void main() {
        Int list = List.new();
        List.push(list, 10);
        List.push(list, 20);
        List.push(list, 30);

        Int len = List.len(list);
        println("len: " + len);

        println("get 0: " + List.get(list, 0));
        println("get 1: " + List.get(list, 1));
        println("get 2: " + List.get(list, 2));
    }
}
