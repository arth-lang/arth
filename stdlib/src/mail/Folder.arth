    /// Moves messages to another folder (copy + delete).
    @intrinsic("mail.folder.move_messages")
    public static async void moveMessages(Folder self, MimeMessage[] messages, Folder destination)
        throws (FolderError, TimeoutError) {
        // Intrinsic implementation - placeholder
    }

    /// Appends a message to the folder.
    @intrinsic("mail.folder.append_message")
    public static async void appendMessage(Folder self, MimeMessage message)
