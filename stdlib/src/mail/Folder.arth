// ─────────────────────────────────────────────────────────────────────────────
// Search Terms
// ─────────────────────────────────────────────────────────────────────────────

/**
 * Search term type.
 */
public enum SearchTermType {
    /// All messages
    ALL,
    /// Messages matching all sub-terms
    AND,
    /// Messages matching any sub-term
    OR,
    /// Negation of a term
    NOT,
    /// Messages marked as seen/read
    SEEN,
    /// Messages not marked as seen
    UNSEEN,
    /// Messages marked as flagged
    FLAGGED,
    /// Messages marked as deleted
    DELETED,
    /// Messages from a specific sender
    FROM,
    /// Messages to a specific recipient
    TO,
    /// Messages with subject containing text
    SUBJECT,
    /// Messages with body containing text
    BODY,
    /// Messages with any text containing text
    TEXT,
    /// Messages before a date
    BEFORE,
    /// Messages on a date
    ON,
    /// Messages since a date
    SINCE,
    /// Messages larger than size
    LARGER,
    /// Messages smaller than size
    SMALLER,
    /// Messages with specific header
    HEADER
}

/**
 * Represents a search term for searching messages.
 */
public struct SearchTerm {
    /// Term type
    public final SearchTermType termType;
    /// String value (for FROM, TO, SUBJECT, BODY, TEXT, HEADER)
    public final String stringValue;
    /// Header name (for HEADER)
    public final String headerName;
    /// Date value (for BEFORE, ON, SINCE)
    public final String dateValue;
    /// Size value (for LARGER, SMALLER)
    public final int sizeValue;
    /// Sub-terms (for AND, OR, NOT)
    public final int subTermsHandle;
}

module SearchTerm {
    /// Matches all messages.
    public static SearchTerm all() {
        return SearchTerm {
            termType: SearchTermType.ALL,
            stringValue: "",
            headerName: "",
            dateValue: "",
            sizeValue: 0,
            subTermsHandle: 0
        };
    }

    /// Matches unread messages.
    public static SearchTerm unread() {
        return SearchTerm {
            termType: SearchTermType.UNSEEN,
            stringValue: "",
            headerName: "",
            dateValue: "",
            sizeValue: 0,
            subTermsHandle: 0
        };
    }

    /// Matches read messages.
    public static SearchTerm read() {
        return SearchTerm {
            termType: SearchTermType.SEEN,
            stringValue: "",
            headerName: "",
            dateValue: "",
            sizeValue: 0,
            subTermsHandle: 0
        };
    }

    /// Matches flagged messages.
    public static SearchTerm flagged() {
        return SearchTerm {
            termType: SearchTermType.FLAGGED,
            stringValue: "",
            headerName: "",
            dateValue: "",
            sizeValue: 0,
            subTermsHandle: 0
        };
    }

    /// Matches deleted messages.
    public static SearchTerm deleted() {
        return SearchTerm {
            termType: SearchTermType.DELETED,
            stringValue: "",
            headerName: "",
            dateValue: "",
            sizeValue: 0,
            subTermsHandle: 0
        };
    }

    /// Matches messages from a sender.
    public static SearchTerm from(String address) {
        return SearchTerm {
            termType: SearchTermType.FROM,
            stringValue: address,
            headerName: "",
            dateValue: "",
            sizeValue: 0,
            subTermsHandle: 0
        };
    }

    /// Matches messages to a recipient.
    public static SearchTerm to(String address) {
        return SearchTerm {
            termType: SearchTermType.TO,
            stringValue: address,
            headerName: "",
            dateValue: "",
            sizeValue: 0,
            subTermsHandle: 0
        };
    }

    /// Matches messages with subject containing text.
    public static SearchTerm subject(String text) {
        return SearchTerm {
            termType: SearchTermType.SUBJECT,
            stringValue: text,
            headerName: "",
            dateValue: "",
            sizeValue: 0,
            subTermsHandle: 0
        };
    }

    /// Matches messages with body containing text.
    public static SearchTerm body(String text) {
        return SearchTerm {
            termType: SearchTermType.BODY,
            stringValue: text,
            headerName: "",
            dateValue: "",
            sizeValue: 0,
            subTermsHandle: 0
        };
    }

    /// Matches messages with any part containing text.
    public static SearchTerm text(String text) {
        return SearchTerm {
            termType: SearchTermType.TEXT,
            stringValue: text,
            headerName: "",
            dateValue: "",
            sizeValue: 0,
            subTermsHandle: 0
        };
    }

    /// Matches messages with a specific header value.
    public static SearchTerm header(String name, String value) {
        return SearchTerm {
            termType: SearchTermType.HEADER,
            stringValue: value,
            headerName: name,
            dateValue: "",
            sizeValue: 0,
            subTermsHandle: 0
        };
    }

    /// Matches messages larger than size bytes.
    public static SearchTerm larger(int size) {
        return SearchTerm {
            termType: SearchTermType.LARGER,
            stringValue: "",
            headerName: "",
            dateValue: "",
            sizeValue: size,
            subTermsHandle: 0
        };
    }

    /// Matches messages smaller than size bytes.
    public static SearchTerm smaller(int size) {
        return SearchTerm {
            termType: SearchTermType.SMALLER,
            stringValue: "",
            headerName: "",
            dateValue: "",
            sizeValue: size,
            subTermsHandle: 0
        };
    }

    /// Combines terms with AND.
    @intrinsic("mail.search.and")
    public static SearchTerm and(SearchTerm a, SearchTerm b) {
        // Intrinsic implementation - placeholder
        return a;
    }

    /// Combines terms with OR.
    @intrinsic("mail.search.or")
    public static SearchTerm or(SearchTerm a, SearchTerm b) {
        // Intrinsic implementation - placeholder
        return a;
    }

    /// Negates a term.
    @intrinsic("mail.search.not")
    public static SearchTerm not(SearchTerm term) {
        // Intrinsic implementation - placeholder
        return term;
    }
}
