package mail;

/**
 * Mailbox folder operations.
 *
 * A Folder represents a mailbox folder (INBOX, Sent, Drafts, etc.) on an
 * IMAP or POP3 server.
 *
 * Example usage:
 * ```arth
 * import mail.*;
 *
 * // Open inbox and read messages
 * Folder inbox = Store.getInbox(store);
 * await Folder.open(inbox, FolderMode.READ_ONLY);
 *
 * int count = Folder.getMessageCount(inbox);
 * Console.println("You have " + count + " messages");
 *
 * // Get recent messages
 * Message[] messages = await Folder.getMessages(inbox, count - 10, count);
 *
 * // Search for unread messages
 * Message[] unread = await Folder.search(inbox, SearchTerm.unread());
 *
 * Folder.close(inbox, false);
 * ```
 *
 * @see mail.Store for connecting to mail stores
 * @see mail.Message for working with messages
 */

// ─────────────────────────────────────────────────────────────────────────────
// Folder Mode
// ─────────────────────────────────────────────────────────────────────────────

/**
 * Folder open mode.
 */
public enum FolderMode {
    /// Read-only access (cannot modify messages)
    READ_ONLY,
    /// Read-write access (can modify messages, expunge)
    READ_WRITE
}

// ─────────────────────────────────────────────────────────────────────────────
// Folder State
// ─────────────────────────────────────────────────────────────────────────────

/**
 * Folder state.
 */
public enum FolderState {
    /// Folder is closed
    CLOSED,
    /// Folder is open for reading
    OPEN_READ_ONLY,
    /// Folder is open for reading and writing
    OPEN_READ_WRITE
}

// ─────────────────────────────────────────────────────────────────────────────
// Folder Type
// ─────────────────────────────────────────────────────────────────────────────

/**
 * Well-known folder types.
 */
public enum FolderType {
    /// Primary inbox
    INBOX,
    /// Sent messages
    SENT,
    /// Draft messages
    DRAFTS,
    /// Deleted messages (trash)
    TRASH,
    /// Spam/junk messages
    SPAM,
    /// Archived messages
    ARCHIVE,
    /// Custom user folder
    CUSTOM
}

// ─────────────────────────────────────────────────────────────────────────────
// Folder Structure
// ─────────────────────────────────────────────────────────────────────────────

/**
 * Represents a mailbox folder.
 */
public struct Folder {
    /// Opaque folder handle
    public final int handle;
    /// Parent store
    public final Store store;
    /// Folder name (short name, e.g., "INBOX")
    public final String name;
    /// Full folder path (e.g., "INBOX/Subfolder")
    public final String fullName;
    /// Folder type
    public final FolderType folderType;
    /// Current state
    public final FolderState state;
    /// Total message count (when open)
    public final int messageCount;
    /// Unread message count (when open)
    public final int unreadCount;
    /// Recent message count (when open)
    public final int recentCount;
}

module Folder {
    // ─────────────────────────────────────────────────────────────────────────
    // Open/Close
    // ─────────────────────────────────────────────────────────────────────────

    /// Opens the folder for access.
    @intrinsic("mail.folder.open")
    public static async Folder open(Folder self, FolderMode mode)
        throws (FolderError, TimeoutError) {
        // Intrinsic implementation - placeholder
        FolderState newState = mode == FolderMode.READ_ONLY ?
            FolderState.OPEN_READ_ONLY : FolderState.OPEN_READ_WRITE;

        return Folder {
            handle: self.handle,
            store: self.store,
            name: self.name,
            fullName: self.fullName,
            folderType: self.folderType,
            state: newState,
            messageCount: 0,
            unreadCount: 0,
            recentCount: 0
        };
    }

    /// Closes the folder.
    ///
    /// @param expunge If true, permanently removes messages marked for deletion
    @intrinsic("mail.folder.close")
    public static void close(Folder self, bool expunge) throws (FolderError) {
        // Intrinsic implementation - placeholder
    }

    /// Returns true if the folder is open.
    public static bool isOpen(Folder self) {
        return self.state != FolderState.CLOSED;
    }

    /// Returns the folder state.
    public static FolderState getState(Folder self) {
        return self.state;
    }

    /// Returns the folder mode (if open).
    public static FolderMode getMode(Folder self) {
        if (self.state == FolderState.OPEN_READ_WRITE) {
            return FolderMode.READ_WRITE;
        }
        return FolderMode.READ_ONLY;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Folder Properties
    // ─────────────────────────────────────────────────────────────────────────

    /// Returns the folder name.
    public static String getName(Folder self) {
        return self.name;
    }

    /// Returns the full folder path.
    public static String getFullName(Folder self) {
        return self.fullName;
    }

    /// Returns the folder type.
    public static FolderType getFolderType(Folder self) {
        return self.folderType;
    }

    /// Returns the parent store.
    public static Store getStore(Folder self) {
        return self.store;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Message Counts
    // ─────────────────────────────────────────────────────────────────────────

    /// Returns the total message count.
    @intrinsic("mail.folder.get_message_count")
    public static int getMessageCount(Folder self) throws (FolderError) {
        return self.messageCount;
    }

    /// Returns the unread message count.
    @intrinsic("mail.folder.get_unread_count")
    public static int getUnreadCount(Folder self) throws (FolderError) {
        return self.unreadCount;
    }

    /// Returns the recent message count (new since last session).
    @intrinsic("mail.folder.get_recent_count")
    public static int getRecentCount(Folder self) throws (FolderError) {
        return self.recentCount;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Message Access
    // ─────────────────────────────────────────────────────────────────────────

    /// Returns a message by sequence number (1-based).
    @intrinsic("mail.folder.get_message")
    public static async MimeMessage getMessage(Folder self, int msgNum)
        throws (FolderError, TimeoutError) {
        // Intrinsic implementation - placeholder
        return MimeMessage.empty();
    }

    /// Returns a message by UID.
    @intrinsic("mail.folder.get_message_by_uid")
    public static async MimeMessage getMessageByUid(Folder self, int64 uid)
        throws (FolderError, TimeoutError) {
        // Intrinsic implementation - placeholder
        return MimeMessage.empty();
    }

    /// Returns all messages in the folder.
    @intrinsic("mail.folder.get_messages")
    public static async MimeMessage[] getMessages(Folder self)
        throws (FolderError, TimeoutError) {
        // Intrinsic implementation - placeholder
        return new MimeMessage[0];
    }

    /// Returns messages in a range (1-based, inclusive).
    @intrinsic("mail.folder.get_messages_range")
    public static async MimeMessage[] getMessagesRange(Folder self, int start, int end)
        throws (FolderError, TimeoutError) {
        // Intrinsic implementation - placeholder
        return new MimeMessage[0];
