    // ─────────────────────────────────────────────────────────────────────────
    // Message Operations
    // ─────────────────────────────────────────────────────────────────────────

    /// Copies messages to another folder.
    @intrinsic("mail.folder.copy_messages")
    public static async void copyMessages(Folder self, MimeMessage[] messages, Folder destination)
