    }

    /// Marks a message as deleted.
    @intrinsic("mail.folder.set_deleted")
    public static void setDeleted(Folder self, MimeMessage msg, bool deleted)
        throws (FolderError) {
        // Intrinsic implementation - placeholder
    }

    /// Permanently removes messages marked for deletion.
    @intrinsic("mail.folder.expunge")
    public static async void expunge(Folder self) throws (FolderError, TimeoutError) {
