    }

    // ─────────────────────────────────────────────────────────────────────────
    // Search
    // ─────────────────────────────────────────────────────────────────────────

    /// Searches for messages matching a search term.
    @intrinsic("mail.folder.search")
    public static async MimeMessage[] search(Folder self, SearchTerm term)
        throws (FolderError, TimeoutError) {
        // Intrinsic implementation - placeholder
        return new MimeMessage[0];
    }

    /// Searches and returns only UIDs (more efficient).
    @intrinsic("mail.folder.search_uids")
    public static async int64[] searchUids(Folder self, SearchTerm term)
        throws (FolderError, TimeoutError) {
        // Intrinsic implementation - placeholder
        return new int64[0];
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Message Modification
    // ─────────────────────────────────────────────────────────────────────────

    /// Marks a message as read/seen.
    @intrinsic("mail.folder.set_seen")
    public static void setSeen(Folder self, MimeMessage msg, bool seen)
