{
  "name": "arth-vscode",
  "displayName": "Arth",
  "description": "Arth language support powered by arth-lsp",
  "version": "0.0.2",
  "publisher": "arth-lang",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:arth"
  ],
  "contributes": {
    "languages": [
      {
        "id": "arth",
        "aliases": [
          "Arth",
          "arth"
        ],
        "extensions": [
          ".arth"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "arth",
        "scopeName": "source.arth",
        "path": "./syntaxes/arth.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Arth",
      "properties": {
        "arth-lsp.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to arth-lsp executable. Leave empty to auto-detect (target/debug or PATH)."
        }
      }
    },
    "commands": [
      {
        "command": "arth.restartServer",
        "title": "Arth: Restart Language Server"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0",
    "vsce": "^2.15.0",
    "vscode": "^1.1.37"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
